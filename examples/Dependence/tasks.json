{
    "tasks": [
        {
            "label": "JLink Flash",
            "type": "shell",
            "command": "D:\\SEGGER\\JLink_V924a\\JLink.exe",
            "args": [
                "-commanderscript",
                "flash.jlink"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "detail": "烧录ELF文件"
        },
        {
            "label": "Generate JLink Script",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "(echo device STM32F103C8 & echo si SWD & echo speed 4000 & echo connect & echo erase & echo loadfile \"./build/Release/${workspaceFolderBasename}.elf\" & echo reset & echo go & echo exit) > \"${workspaceFolder}\\flash.jlink\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        
